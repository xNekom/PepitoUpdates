# Variables de Entorno — PépitoUpdates
# Copia este archivo como .env y completa los valores reales.
# ⚠️  NUNCA subas credenciales reales a Git (.env está en .gitignore)
#
# USO:
#   flutter run --dart-define-from-file=.env
#
# FORMATO:
#   CLAVE=valor
#   (sin comillas alrededor del valor, sin espacios alrededor de =)
#
# Variables requeridas:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SENTRY_DSN=https://your-dsn@sentry.io/12345

# Variables opcionales:
API_BASE_URL=https://api.thecatdoor.com
ENVIRONMENT=development
